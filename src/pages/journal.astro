---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Studio notes, project documentation, artwork process, and material investigations from Rob White Studio.";
---

<BaseLayout title="Journal | Rob White Studio" description={description} activePage="journal" footerLabel="Journal / Process / Archive">
  <section class="journal-hero color-band color-band-ochre">
    <p class="eyebrow">Journal</p>
    <h1>Studio notes, process records, material tests, and the business of building the practice.</h1>
  </section>

  <section class="journal-layout ruled-section">
    <aside class="journal-sidebar" aria-label="Journal information">
      <p class="eyebrow">Public Journal</p>
      <p>Selected studio records will appear here when they are ready to publish.</p>
    </aside>
    <div class="journal-list">
      <article class="journal-entry journal-public-empty">
        <p class="meta">Archive in progress</p>
        <h2>The working Journal is now being assembled.</h2>
        <p>
          Rob White Studio uses a private Journal to record ideas, decisions,
          process, materials, problems, and lessons. Selected entries will be
          shaped into public studio stories over time.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
